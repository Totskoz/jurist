# Claude API key. The app boots without it (lifespan only constructs the
# client), but `/api/ask` fails at first tool call. Leave blank to run
# with the fake agents only (M0 path).
ANTHROPIC_API_KEY=

# --- Optional overrides (defaults shown) ---------------------------------

# Retriever model. Must be a tool-use capable Claude model.
# JURIST_MODEL_RETRIEVER=claude-sonnet-4-6

# Max tool-use iterations before the loop coerces with a visit-recency
# selection. Spec §5 default is 15.
# JURIST_MAX_RETRIEVER_ITERS=15

# Wall-clock cap for a single retriever run, in seconds. On cap, the loop
# yields Coerced(reason="wall_clock").
# JURIST_RETRIEVER_WALL_CLOCK_CAP_S=180

# Characters of body_text included in each catalog row's snippet. Affects
# prompt size: ~66KB at 200 chars across 218 articles.
# JURIST_STATUTE_CATALOG_SNIPPET_CHARS=200

# SSE event buffer depth per run (see CLAUDE.md "Environment quirks" —
# full M0 run emits ~184 events, so 500 is comfortable headroom).
# JURIST_MAX_HISTORY_PER_RUN=500

# CORS origin for the Vite dev server.
# JURIST_CORS_ORIGIN=http://localhost:5173

# Data directory (contains kg/huurrecht.json built by jurist.ingest.statutes).
# JURIST_DATA_DIR=./data

# --- Optional: integration tests -----------------------------------------
# Set RUN_E2E=1 to opt into the real-Anthropic integration test
# (costs tokens). Never needed for unit runs.
# RUN_E2E=1

# --- M3b: case retriever -----------------------------------------------

# Rerank model. Must be a Claude tool-use capable model.
# JURIST_MODEL_RERANK=claude-haiku-4-5-20251001

# Cosine over-fetch pool (chunks) before ECLI-dedupe. M3a corpus averages
# ~7.8 chunks/case, so 150 chunks statistically dedupes to ≥20 unique ECLIs.
# JURIST_CASELAW_CANDIDATE_CHUNKS=150

# Cap on unique ECLIs reaching the rerank.
# JURIST_CASELAW_CANDIDATE_ECLIS=20

# Chunk-text excerpt length per candidate (in the rerank prompt).
# JURIST_CASELAW_RERANK_SNIPPET_CHARS=400

# --- M4: decomposer + synthesizer -------------------------------------

# Decomposer model. Small structured-output task.
# JURIST_MODEL_DECOMPOSER=claude-haiku-4-5-20251001

# Synthesizer model. Dutch structured generation with closed-set citations.
# JURIST_MODEL_SYNTHESIZER=claude-sonnet-4-6

# Budget for synthesizer reasoning prose + structured output combined.
# Tool-input payload is typically ≤2kT; thinking can add another 1-2kT.
# JURIST_SYNTHESIZER_MAX_TOKENS=8192

# --- M5: answer quality -----------------------------------------------

# M5 — case retriever low-confidence threshold (cosine floor below which all
# three reranked cases trip CaseRetrieverOut.low_confidence=True)
# JURIST_CASE_SIMILARITY_FLOOR=0.55
