__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Environment files (never commit secrets)
.env
.env.*
!.env.example

# Node / Vite
node_modules/
dist/
.vite/
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Worktrees
.worktrees/

# Real-API eval run artefacts (trace.jsonl + summary.json + answer.md)
out/
